# AI 프록시 (Cloudflare Worker) — proxy/README.md 참고해 배포 후 값 입력
# 앱은 Claude API 를 직접 호출하지 않고 이 프록시를 통해 호출합니다.

# 배포된 Worker URL
EXPO_PUBLIC_PROXY_URL=https://routine-tracker-proxy.your-account.workers.dev

# Worker 의 APP_SHARED_SECRET 과 동일한 값 (예: openssl rand -hex 32)
EXPO_PUBLIC_PROXY_TOKEN=your-long-random-shared-secret
